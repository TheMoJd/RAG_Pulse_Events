# Clé API Mistral (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# Modèle Mistral pour la génération (par défaut: mistral-small-latest)
MISTRAL_MODEL=mistral-medium-latest

# Ville cible pour la recherche d'événements Open Agenda
TARGET_CITY=Paris

# Fenêtre d'anticipation (en jours) : on indexe les events qui commencent dans
# les N prochains jours et ne sont pas encore terminés.
# 120 = "ce printemps + cet été" (~4 mois)
LOOKAHEAD_DAYS=120
