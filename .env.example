# Clé API Mistral (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# Modèle Mistral pour la génération (par défaut: mistral-small-latest)
MISTRAL_MODEL=mistral-small-latest

# Ville cible pour la recherche d'événements Open Agenda
TARGET_CITY=Brest

# Fenêtre temporelle (en jours) pour les événements indexés
SINCE_DAYS=365
